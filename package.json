{
  "name": "caelus-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w caelus && npm run build -w caelus-mcp && npm run build -w caelus-birth && npm run build -w caelus-wheel && npm run build -w web",
    "test": "npm run test -w caelus",
    "lint:prose": "bash scripts/lint-prose.sh",
    "lint:claims": "node scripts/check-claims.mjs",
    "docs:api": "typedoc",
    "eval:selfcheck": "node packages/caelus-mcp/eval/run.mjs",
    "dev:web": "npm run dev -w web",
    "dev:web:clean": "npm run dev:clean -w web"
  },
  "devDependencies": {
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0"
  }
}
